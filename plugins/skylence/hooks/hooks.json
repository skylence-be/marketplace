{
  "description": "Judge hook (PreToolUse rules engine, opt-in via ~/.claude/judge-rules.json) + SessionStart steer to prefer skyline MCP tools over built-in file tools.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit|mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/judge-hook.sh\"",
            "statusMessage": "Judging tool call..."
          }
        ]
      }
    ]
  }
}