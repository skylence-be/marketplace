{
  "skyway": {
    "command": "skyway",
    "args": ["lsp", "stdio"],
    "extensionToLanguage": {
      ".sky": "sky-workflow"
    },
    "transport": "stdio",
    "startupTimeout": 10000,
    "shutdownTimeout": 5000,
    "maxRestarts": 3
  },
  "cpp-lsp": {
    "command": "clangd",
    "args": ["--background-index"],
    "extensionToLanguage": {
      ".c": "c",
      ".h": "c",
      ".cpp": "cpp",
      ".cc": "cpp",
      ".cxx": "cpp",
      ".hpp": "cpp",
      ".hxx": "cpp",
      ".C": "cpp",
      ".H": "cpp"
    }
  },
  "csharp-lsp": {
    "command": "csharp-ls",
    "extensionToLanguage": {
      ".cs": "csharp"
    }
  },
  "go-lsp": {
    "command": "gopls",
    "extensionToLanguage": {
      ".go": "go"
    }
  },
  "java-lsp": {
    "command": "jdtls",
    "extensionToLanguage": {
      ".java": "java"
    },
    "startupTimeout": 120000
  },
  "kotlin-lsp": {
    "command": "kotlin-lsp",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".kt": "kotlin",
      ".kts": "kotlin"
    },
    "startupTimeout": 120000
  },
  "lua-lsp": {
    "command": "lua-language-server",
    "extensionToLanguage": {
      ".lua": "lua"
    }
  },
  "php-lsp": {
    "command": "intelephense",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".php": "php"
    }
  },
  "python-lsp": {
    "command": "pyright-langserver",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".py": "python",
      ".pyi": "python"
    }
  },
  "ruby-lsp": {
    "command": "ruby-lsp",
    "extensionToLanguage": {
      ".rb": "ruby",
      ".rake": "ruby",
      ".gemspec": "ruby",
      ".ru": "ruby",
      ".erb": "erb"
    }
  },
  "rust-lsp": {
    "command": "rust-analyzer",
    "extensionToLanguage": {
      ".rs": "rust"
    }
  },
  "swift-lsp": {
    "command": "sourcekit-lsp",
    "extensionToLanguage": {
      ".swift": "swift"
    }
  },
  "typescript-lsp": {
    "command": "typescript-language-server",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".ts": "typescript",
      ".tsx": "typescriptreact",
      ".js": "javascript",
      ".jsx": "javascriptreact",
      ".mts": "typescript",
      ".cts": "typescript",
      ".mjs": "javascript",
      ".cjs": "javascript"
    }
  }
}
