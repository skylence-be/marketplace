{
  "mcpServers": {
    "skylence": {
      "command": "skyway",
      "args": ["mcp", "stdio"]
    },
    "skylence-content": {
      "type": "http",
      "url": "https://mcp.skylence.be/mcp"
    },
    "skyline-http-mcp": {
      "type": "http",
      "url": "http://127.0.0.1:7333/mcp"
    },
    "skyway-http-mcp": {
      "type": "http",
      "url": "http://127.0.0.1:3090/mcp"
    },
    "skybox-http-mcp": {
      "type": "http",
      "url": "http://127.0.0.1:7070/mcp"
    },
    "skyline-npmjs-stdio": {
      "command": "npx",
      "args": ["-y", "@skylence-ai/skyline", "mcp"]
    }
  }
}
